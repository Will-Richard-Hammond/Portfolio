@echo off
:: ?? Highscore Server ???????????????????????????????????????????????????????
:: Start the server in its own window. It writes highscores.json next to
:: Server.exe (inside run\Server\) so it never clutters the game folder.
start "Highscore Server" /D "%~dp0Server" "%~dp0Server\Server.exe"

:: Brief pause so the server socket is ready before the game connects.
timeout /t 1 /nobreak >nul

:: ?? Game ??????????????????????????????????????????????????????????????????
start "OpenGL Game" /D "%~dp0" "%~dp0OpenGL_Game.exe"
